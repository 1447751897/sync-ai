{
  "name": "sync-ai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "sync-ai：面向 Codex 的本地多模型能力路由插件与可视化控制台。",
  "scripts": {
    "build": "tsc && npm run copy-static",
    "copy-static": "node scripts/copy-static.mjs",
    "test": "vitest run",
    "dev:config": "tsx src/http/server.ts",
    "start:config": "node dist/http/server.js",
    "mcp": "node dist/mcp/server.js",
    "mcp:dev": "tsx src/mcp/server.ts",
    "desktop:dev": "npm run build && electron .",
    "desktop:pack": "npm run build && electron-builder --win portable --x64",
    "desktop:dir": "npm run build && electron-builder --dir --win --x64"
  },
  "keywords": [
    "codex",
    "mcp",
    "capability-routing",
    "image-generation",
    "openai-compatible"
  ],
  "author": {
    "name": "zhuzhenyu"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "latest",
    "undici": "^8.7.0",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  },
  "main": "desktop/main.cjs",
  "build": {
    "appId": "com.syncai.desktop",
    "productName": "sync-ai",
    "directories": {
      "output": "release"
    },
    "files": [
      "desktop/**/*",
      "dist/**/*",
      "package.json",
      "node_modules/**/*",
      ".codex-plugin/**/*",
      ".mcp.json",
      "README.md",
      "docs/user-guide/**/*"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "artifactName": "sync-ai-${version}-${arch}.${ext}"
    }
  }
}
